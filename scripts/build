#!/bin/bash

# Always-on flags for GCC 16.1
# -march=native: Optimize for the current CPU instructions (AVX2/NEON)
#
# Opt-in flags such as -fmodules, -flto and -freflection live in
# experimental-flags and are passed in via "$@" only when the user
# checks them in the UI.
OPT_FLAGS="-march=native"

$CXX $OPT_FLAGS "$@" bench-file.cpp -o bench \
    -lada \
    -lfmt \
    -lboost_regex \
    -lboost_filesystem \
    -lboost_atomic \
    -lbenchmark_main \
    -lbenchmark \
    -ljemalloc \
    -lsnappy \
    -lhiredis \
    -luv \
    -lyaml-cpp \
    -lssl \
    -lcrypto \
    -lpthread \
    -lrt \
    -ldl
